{
  "name": "auditnotes",
  "publisher": "hyckomatej",
  "displayName": "AuditNotes",
  "description": "Add color-coded audit notes to code selections, review them in a sidebar, and copy them as Markdown.",
  "icon": "assets/icon.png",
  "version": "0.0.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyckomatej/auditnotes.git"
  },
  "homepage": "https://github.com/hyckomatej/auditnotes#readme",
  "bugs": {
    "url": "https://github.com/hyckomatej/auditnotes/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.audit-notes.json"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "audit",
    "notes",
    "security",
    "review",
    "code review",
    "annotations",
    "markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Audit Notes",
      "properties": {
        "auditnotes.defaultColor": {
          "type": "string",
          "default": "rgba(255, 255, 255, 0.2)",
          "description": "The default background color for new audit notes."
        }
      }
    },
    "commands": [
      {
        "command": "auditnotes.addNote",
        "title": "Add Audit Note",
        "category": "AuditNotes"
      },
      {
        "command": "auditnotes.editNote",
        "title": "Edit Audit Note",
        "category": "AuditNotes"
      },
      {
        "command": "auditnotes.deleteNote",
        "title": "Delete Audit Note",
        "category": "AuditNotes"
      },
      {
        "command": "auditnotes.toggleVisibility",
        "title": "Toggle Audit Notes Visibility",
        "category": "AuditNotes"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "auditnotes-explorer",
          "title": "Audit Notes",
          "icon": "$(note)"
        }
      ]
    },
    "views": {
      "auditnotes-explorer": [
        {
          "type": "webview",
          "id": "auditnotes.sidebar",
          "name": "Note Details"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "auditnotes.addNote",
          "group": "auditnotes@1",
          "when": "editorHasSelection"
        },
        {
          "command": "auditnotes.editNote",
          "group": "auditnotes@1",
          "when": "editorTextFocus"
        },
        {
          "command": "auditnotes.deleteNote",
          "group": "auditnotes@1",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "undici-types": "^7.24.6"
  }
}
